generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════
// PLATFORM (NexCRM Owner)
// ═══════════════════════════════

model Company {
  id          Int      @id @default(autoincrement())
  nom         String
  slug        String   @unique  // ex: "ecolea" → nexcrm.ma/form/ecolea
  email       String   @unique
  tel         String?
  ville       String?
  plan        Plan     @default(BASIC)
  statut      CompanyStatut @default(ACTIF)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  leads       Lead[]
  integrations Integration[]
  formConfig  FormConfig?

  @@map("companies")
}

model Integration {
  id          Int      @id @default(autoincrement())
  companyId   Int
  source      SourceType
  actif       Boolean  @default(false)
  config      Json?    // tokens, page ids, etc.
  webhookUrl  String?
  leadsCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, source])
  @@map("integrations")
}

model FormConfig {
  id          Int      @id @default(autoincrement())
  companyId   Int      @unique
  titre       String   @default("Inscrivez-vous")
  sousTitre   String?
  description String?
  couleur     String   @default("#1a3a5c")
  logo        String?
  formations  String[] @default([])
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("form_configs")
}

// ═══════════════════════════════
// USERS
// ═══════════════════════════════

model User {
  id          Int      @id @default(autoincrement())
  companyId   Int?     // null = Platform Owner
  email       String   @unique
  password    String
  nom         String
  role        Role     @default(COMMERCIAL)
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leads       Lead[]
  activites   Activite[]

  @@map("users")
}

// ═══════════════════════════════
// LEADS
// ═══════════════════════════════

model Lead {
  id          Int      @id @default(autoincrement())
  companyId   Int
  userId      Int?     // commercial assigné
  nom         String
  email       String?
  tel         String
  ville       String?
  formation   String
  statut      Statut   @default(NOUVEAU)
  source      SourceType @default(SITE_WEB)
  notes       String?
  dateContact DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conseiller  User?    @relation(fields: [userId], references: [id])
  activites   Activite[]

  @@map("leads")
}

model Activite {
  id          Int      @id @default(autoincrement())
  leadId      Int
  userId      Int?
  type        String   // appel, email, note, rdv, whatsapp
  contenu     String
  date        DateTime @default(now())

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])

  @@map("activites")
}

// ═══════════════════════════════
// ENUMS
// ═══════════════════════════════

enum Role {
  PLATFORM_OWNER
  COMPANY_ADMIN
  DIRECTEUR
  COMMERCIAL
  COMPTABILITE
}

enum Plan {
  BASIC
  PRO
  ENTERPRISE
}

enum CompanyStatut {
  ACTIF
  SUSPENDU
  ESSAI
  EXPIRE
}

enum Statut {
  NOUVEAU
  A_APPELER
  CONTACTE
  INTERESSE
  RDV
  PAIEMENT
  INSCRIT
  PERDU
}

enum SourceType {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  SITE_WEB
  WHATSAPP
  QR_CODE
  AUTRE
}
